{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "dev": "node ./scripts/dev.mjs",
    "dev:server": "node ./scripts/dev-server.mjs",
    "dev:web": "node ./scripts/dev-web.mjs",
    "start": "pnpm --filter @meta-search/server start",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
