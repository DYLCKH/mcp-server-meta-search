{
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6"
  },
  "scripts": {
    "build": "bun ./scripts/build-workspace.mjs",
    "test": "bun ./scripts/embed-config-example.mjs && vitest run",
    "dev": "bun ./scripts/dev.mjs",
    "dev:server": "bun ./scripts/dev-server.mjs",
    "dev:web": "bun ./scripts/dev-web.mjs",
    "start": "bun run --filter @meta-search/server start",
    "clean": "bun ./scripts/clean.mjs",
    "build:binary": "bun ./scripts/build-binary.mjs",
    "embed-assets": "bun ./scripts/embed-assets.mjs",
    "embed-config-example": "bun ./scripts/embed-config-example.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
