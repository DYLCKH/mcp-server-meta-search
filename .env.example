# Required (at least one key per provider you want to use)
TAVILY_API_KEYS=tvly-key-1,tvly-key-2
EXA_API_KEYS=exa-key-1,exa-key-2
PERPLEXITY_API_KEYS=pplx-key-1,pplx-key-2

# Optional single-key fallback (used when *_API_KEYS is not set)
# TAVILY_API_KEY=tvly-key-single
# EXA_API_KEY=exa-key-single
# PERPLEXITY_API_KEY=pplx-key-single

# Optional tuning
# SEARCH_KEY_ROTATION_STRATEGY=round_robin
# SEARCH_MAX_ATTEMPTS_PER_REQUEST=0
# SEARCH_REQUEST_TIMEOUT_MS=30000

# Optional base URL override
# TAVILY_BASE_URL=https://api.tavily.com
# EXA_BASE_URL=https://api.exa.ai
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
