{
  "name": "@meta-search/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun ../../scripts/embed-config-example.mjs && tsup",
    "dev": "bun ../../scripts/embed-config-example.mjs && bun --watch src/index.ts",
    "start": "bun --smol dist/index.js",
    "test": "bun ../../scripts/embed-config-example.mjs && vitest run --passWithNoTests"
  },
  "dependencies": {
    "@meta-search/config": "workspace:*",
    "@meta-search/runtime": "workspace:*",
    "@meta-search/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.7.9",
    "undici": "^7.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  }
}
